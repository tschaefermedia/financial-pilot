# =============================================================================
# FinanzPilot — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your setup.
# In Docker: these can also be set via docker-compose environment variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=FinanzPilot
APP_ENV=production          # production, local
APP_KEY=
APP_DEBUG=false             # Set to true for development
APP_URL=http://localhost    # Your app URL (used for links in exports etc.)

# -----------------------------------------------------------------------------
# Locale
# -----------------------------------------------------------------------------
APP_LOCALE=de
APP_FALLBACK_LOCALE=de

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite        # SQLite is the only supported driver
# DB_DATABASE=              # Default: database/database.sqlite

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
SESSION_DRIVER=file         # file (recommended), cookie, array
SESSION_LIFETIME=120        # Session timeout in minutes

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_STORE=file            # file (recommended), array

# -----------------------------------------------------------------------------
# Queue
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=sync       # sync (recommended for single-user)

# -----------------------------------------------------------------------------
# Filesystem
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error             # debug, info, notice, warning, error, critical
